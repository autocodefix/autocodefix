# AUTO CODE FIX — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. Anthropic AI (AI Diagnosis feature) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── 2. Supabase Database ──────────────────────────────────────────────────────
#
# SETUP STEPS:
#   a) Go to https://supabase.com → New Project
#   b) Run scripts/001_schema.sql in: Dashboard → SQL Editor → Run
#   c) Copy your Project URL and Service Role key below
#   d) Run: npm run seed   (loads all OBD codes into your database)
#
# Project URL  (public — safe to expose)
SUPABASE_URL=https://your-project-id.supabase.co
#
# Service Role key  (SECRET — server-side only, never expose to browser)
# Found in: Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key
#
# ⚠️  If these two vars are NOT set, the app automatically uses the local
#     static codes-db.ts file — so local development works without any DB.


# ── 3. Production domain ──────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://autocodefix.com


# ─────────────────────────────────────────────────────────────────────────────
# Vercel deployment:
#   Add SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, and
#   NEXT_PUBLIC_BASE_URL in: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
